    "confirm_action": {
      "name": "confirm_action",
      "description": "",
      "inputs": [
        {
          "name": "confirmation",
          "type": "string",
          "description": "Short confirmation message logged on call (e.g. 'bid accepted at $1,500').",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "confirmed",
          "type": "boolean",
          "required": false
        },
        {
          "name": "value",
          "type": "string",
          "required": false
        }
      ]
    },
    "evaluate_offer": {
      "name": "evaluate_offer",
      "description": "Evaluate a carrier's rate offer and get instructions on how to respond. Call this every time the carrier gives you a dollar amount. Returns next_steps telling you whether to accept, counter, or stop negotiating. Always increment offer_attempt by 1 on each call — it must always go up.",
      "inputs": [
        {
          "name": "reference_number",
          "type": "string",
          "description": "The load reference number being negotiated (e.g. '0552991')",
          "required": true
        },
        {
          "name": "offer_amount",
          "type": "number",
          "description": "The carrier's latest offer in dollars (numeric only, e.g. 1500)",
          "required": true
        },
        {
          "name": "offer_attempt",
          "type": "integer",
          "description": "Negotiation round number, starting at 1. Increment by 1 each call.",
          "required": true
        },
        {
          "name": "our_last_offer_amount",
          "type": "number",
          "description": "Our previous counter-offer in dollars. Pass 0 on the first call.",
          "required": true
        },
        {
          "name": "truck_empty_location",
          "type": "string",
          "description": "City and state where the carrier's truck will be empty (e.g. 'Chicago, IL')",
          "required": false
        },
        {
          "name": "truck_empty_time",
          "type": "string",
          "description": "Date/time when the truck will be empty (MM-DD-YYYY format, e.g. '04-26-2026')",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "action",
          "type": "string",
          "description": "'accept' | 'counter' | 'decline' | 'unclear' | 'blocked'.",
          "required": false
        },
        {
          "name": "agreed_rate",
          "type": "number",
          "description": "Set when action='accept'.",
          "required": false
        },
        {
          "name": "our_offer",
          "type": "number",
          "description": "Set when action='counter'.",
          "required": false
        },
        {
          "name": "next_steps",
          "type": "string",
          "description": "Instruction text the LLM should follow.",
          "required": false
        },
        {
          "name": "error",
          "type": "string",
          "required": false
        }
      ]
    },
    "find_load": {
      "name": "find_load",
      "description": "",
      "inputs": [],
      "outputs": [
        {
          "name": "found",
          "type": "boolean",
          "description": "True when the load was found and bookable.",
          "required": false
        },
        {
          "name": "success",
          "type": "boolean",
          "required": false
        },
