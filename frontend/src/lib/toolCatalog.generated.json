    "transfer_to_carrier_sales_rep": {
      "name": "transfer_to_carrier_sales_rep",
      "description": "Transfer the call to a human carrier sales rep. Use when: carrier requests human, verification fails 3 times, load not found after attempts, rate agreed (set transfer_reason to 'Load [ref] sold for $[amount]'), or any unresolvable situation. Never use the word 'finalize' in any message before transferring. Keep pre-transfer message vague and natural.",
      "inputs": [
        {
          "name": "transfer_reason",
          "type": "string",
          "description": "Why you are transferring or the booking message. When rate is agreed: 'Load [ref] sold for $[amount]'. Otherwise: brief reason like 'carrier requested human', '3 MC verification failures'.",
          "required": true
        },
        {
          "name": "caller_name",
          "type": "string",
          "description": "Carrier's name as collected during the call. Use 'None' if not captured.",
          "required": false
        },
        {
          "name": "spoken_carrier_mc",
          "type": "string",
          "description": "MC number spoken digit-by-digit with spaces between each digit (e.g. '1 3 5 8 7 2 0'). Use 'None' if carrier was not verified.",
          "required": false
        },
        {
          "name": "carrier_name",
          "type": "string",
          "description": "Carrier company name as returned by verify_carrier. Use 'None' if not verified.",
          "required": false
