{
  "schema_version": "1.0",
  "tools": {
    "ask_for_more_loads": {
      "name": "ask_for_more_loads",
      "description": "After booking a load, ask the carrier if they have more trucks needing loads. Always call this after a successful book_load before wrapping up.",
      "inputs": [],
      "outputs": [
        {
          "name": "success",
          "type": "boolean",
          "required": false
        }
      ]
    },
    "assign_driver": {
      "name": "assign_driver",
      "description": "Assign a driver to a load after agreement. Used in outbound dispatch calls.",
      "inputs": [
        {
          "name": "driver_id",
          "type": "string",
          "description": "Driver ID",
          "required": true
        },
        {
          "name": "load_id",
