        {
          "name": "equipment_type",
          "type": "string",
          "description": "Trailer type: 'Dry Van', 'Reefer', 'Flatbed', 'Step Deck'",
          "required": true
        },
        {
          "name": "destination",
          "type": "string",
          "description": "Optional destination city or state",
          "required": false
        },
        {
          "name": "pickup_date",
          "type": "string",
          "description": "Optional pickup date (e.g. 'today', 'tomorrow', '2026-04-26')",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "loads",
          "type": "array",
          "description": "List of matching loads.",
          "required": false
