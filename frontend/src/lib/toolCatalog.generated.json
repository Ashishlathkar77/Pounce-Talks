    "find_load_by_reference": {
      "name": "find_load_by_reference",
      "description": "Look up a load by reference number — digits only, strip any letters. Requires carrier to be verified first (verify_carrier). Returns load details: origin, destination, equipment, posted_rate, pickup_date, delivery_date.",
      "inputs": [
        {
          "name": "reference_number",
          "type": "string",
          "description": "The load reference number, digits only — strip any letters (e.g. '0527934')",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "found",
          "type": "boolean",
          "required": false
        },
        {
          "name": "success",
          "type": "boolean",
          "required": false
        },
        {
          "name": "ref",
          "type": "string",
          "required": false
