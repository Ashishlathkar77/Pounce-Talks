          "required": true
        }
      ],
      "outputs": [
        {
          "name": "success",
          "type": "boolean",
          "required": false
        },
        {
          "name": "assignment_id",
          "type": "string",
          "required": false
        },
        {
          "name": "error",
          "type": "string",
          "required": false
        }
