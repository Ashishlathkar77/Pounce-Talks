          "required": false
        },
        {
          "name": "attempt",
          "type": "integer",
          "required": false
        }
      ]
    },
    "find_loads_by_lane": {
      "name": "find_loads_by_lane",
      "description": "Search for available loads by lane. Use ONLY when the carrier has no reference number or when find_load fails. Origin and equipment_type are required.",
