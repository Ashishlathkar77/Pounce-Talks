# Pounce backend configuration — copy to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1

# ── Twilio (Elastic SIP trunk feeds LiveKit outbound) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ── STT / TTS ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
TTS_PROVIDER=cartesia

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=
SECRET_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:8000

# ── Demo ──────────────────────────────────────────────────────────────────────
DEMO_MODE=false
DEMO_PHONE_NUMBER=

# ── Integrations ──────────────────────────────────────────────────────────────
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
ORANGE_SLICE_API_KEY=
